{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "baseUrl": ".",
    "paths": {
      "@mela/generated-default-types": ["./generated/default/types/src"],
      "@mela/generated-default-types/*": ["./generated/default/types/src/*"],
      "@mela/generated-default-client": ["./generated/default/client"],
      "@mela/generated-default-client/*": ["./generated/default/client/*"]
    }
  }
}
