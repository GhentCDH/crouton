{
  "name": "@ghentcdh/crouton-forms-vue",
  "version": "0.0.1-alpha.19",
  "repository": {
    "type": "git",
    "url": "https://github.com/GhentCDH/crouton",
    "directory": "packages/crouton-forms-vue"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "type": "module",
  "exports": {
    ".": {
      "@ghentcdh/crouton": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "@ghentcdh/crouton": "./src/testing/index.ts",
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./styles.css": "./styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "styles.css"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.lib.json"
  },
  "dependencies": {
    "vee-validate": "5.0.0-beta.1"
  },
  "peerDependencies": {
    "@ghentcdh/ui": "*",
    "@jsonforms/core": ">=3.0.0",
    "vue": ">=3.0.0",
    "vue-router": ">=4.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ghentcdh/crouton-core": "workspace:*"
  }
}
