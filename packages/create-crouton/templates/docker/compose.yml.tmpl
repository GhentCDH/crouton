services:
  db:
    image: postgres:17
    restart: unless-stopped
    environment:
      POSTGRES_USER: crouton
      POSTGRES_PASSWORD: crouton
      POSTGRES_DB: {{name}}
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data

  app:
    build:
      context: .
      dockerfile: Dockerfile.dev
    restart: unless-stopped
    depends_on:
      - db
    ports:
      - "3000:3000"
    environment:
      DATABASE_URL: postgresql://crouton:crouton@db:5432/{{name}}?schema=public
    volumes:
      - .:/app
      - /app/node_modules

volumes:
  pgdata:
