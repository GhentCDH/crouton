FROM node:22-slim

WORKDIR /app

{{#if nx}}COPY pnpm-workspace.yaml ./
COPY package.json pnpm-lock.yaml ./
COPY apps/backend/package.json ./apps/backend/
{{/if}}{{#if frontend}}COPY apps/frontend/package.json ./apps/frontend/
{{/if}}{{#if regular}}COPY package.json pnpm-lock.yaml ./
{{/if}}
RUN corepack enable && corepack prepare pnpm@latest --activate
RUN pnpm install --frozen-lockfile

COPY . .

EXPOSE 3000

CMD ["pnpm", "dev"]
