FROM node:22-slim AS base
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

# -- deps stage --
FROM base AS deps
{{#if nx}}COPY pnpm-workspace.yaml ./
COPY package.json pnpm-lock.yaml ./
COPY apps/backend/package.json ./apps/backend/
{{/if}}{{#if regular}}COPY package.json pnpm-lock.yaml ./
{{/if}}
RUN pnpm install --frozen-lockfile --prod

# -- build stage --
FROM base AS build
{{#if nx}}COPY pnpm-workspace.yaml ./
COPY package.json pnpm-lock.yaml ./
COPY apps/backend/package.json ./apps/backend/
{{/if}}{{#if regular}}COPY package.json pnpm-lock.yaml ./
{{/if}}
RUN pnpm install --frozen-lockfile
COPY . .
{{#if nx}}RUN pnpm --filter @{{name}}/backend build
{{/if}}{{#if regular}}RUN pnpm build
{{/if}}
# -- production stage --
FROM base AS production
COPY --from=deps /app/node_modules ./node_modules
{{#if nx}}COPY --from=build /app/apps/backend/dist ./dist
{{/if}}{{#if regular}}COPY --from=build /app/dist ./dist
{{/if}}
EXPOSE 3000

CMD ["node", "dist/main.js"]
