packages:
{{#if prefix}}  - {{prefix}}/apps/*
  - {{prefix}}/generated/default/*
{{/if}}{{#if noPrefix}}  - apps/*
  - generated/default/*
{{/if}}  - libs/*

allowBuilds:
  '@swc/core': true
  '@prisma/engines': true
  '@scarf/scarf': true
  esbuild: true
  nx: true
  prisma: true

minimumReleaseAge: 0

onlyBuiltDependencies:
  - '@swc/core'
  - '@prisma/engines'
  - '@scarf/scarf'
  - esbuild
  - nx
  - prisma
