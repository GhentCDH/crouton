import './style.css';
import { createApp } from 'vue';
import {
  useCrouton,
  loadRuntimeConfig,
  getRuntimeConfig,
} from '@ghentcdh/crouton-vue';
import { api } from './api';
import { router } from './router';
import App from './App.vue';

loadRuntimeConfig().then(() => {
  const env = getRuntimeConfig();
  const VERSION =
    env.env === 'PRD'
      ? env.APP_VERSION
      : `${env.APP_VERSION} (${env.env})`;

  useCrouton()
    .init(api, { VERSION, title: '{{Name}}' })
    .then(() => {
      const app = createApp(App);
      app.use(router);
      app.mount('#app');
    });
});
