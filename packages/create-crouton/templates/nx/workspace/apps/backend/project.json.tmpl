{
  "name": "{{#if noPrefix}}{{name}}-{{/if}}{{#if prefix}}{{prefix}}-{{/if}}backend",
  "$schema": "{{schemaPath}}",
  "projectType": "application",
  "sourceRoot": "{{appsRoot}}/backend/src",
  "tags": ["scope:backend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/backend"],
      "options": {
        "commands": ["tsup"],
        "cwd": "{{appsRoot}}/backend"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nodemon",
        "cwd": "{{appsRoot}}/backend",
        "envFile": "{{appsRoot}}/.env"
      }
    }
  }
}
