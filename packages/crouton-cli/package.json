{
  "name": "@ghentcdh/crouton-cli",
  "version": "0.0.1-alpha.22",
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "type": "module",
  "exports": {
    ".": {
      "@ghentcdh/crouton": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./create-datasource": {
      "@ghentcdh/crouton": "./src/create-datasource/index.ts",
      "import": "./dist/create-datasource/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GhentCDH/crouton",
    "directory": "packages/crouton-cli"
  },
  "bin": {
    "crouton": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@prisma/internals": "^7.0.0"
  },
  "devDependencies": {
    "@clack/prompts": "^0.11.0",
    "@ghentcdh/crouton-codegen": "workspace:*",
    "commander": "^14.0.0",
    "picocolors": "^1.1.0",
    "tsup": "^8.0.0"
  }
}
